{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "prompt-royale",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "Room"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Room"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
